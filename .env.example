# Database Configuration — same Postgres instance/credentials the Go API uses
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=

# Security — must match the Go API's JWT_SECRET (both services verify the same tokens)
JWT_SECRET=

# Points at the Go API — same value as the Go backend's own API_BASE_URL
API_BASE_URL=http://localhost:8082

# Optional — port this Flask admin panel listens on when run directly (python run.py)
ADMIN_PORT=5000
